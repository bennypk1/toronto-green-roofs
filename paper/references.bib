	month = jul,
	year = {2023},
	file = {PDF:/Users/benedictcummins-mburu/Zotero/storage/8GPY9AWW/Intergovernmental Panel On Climate Change (Ipcc) - 2023 - Climate Change 2021 – The Physical Science Basis Working Group I Contribution to the Sixth Assessme.pdf:application/pdf},
}

